{%- set server_name = grains.host %}
{%- set os_version = grains.osrelease %}
{#%- macro render_list_of_dictionaries(name, list, indent = '    ', infix = ' ', postfix = '\t') %#}
{%- macro render_list_of_dictionaries(name, list, indent = '    ', infix = ' ', postfix = ' ') %}
{%- if list is not iterable or list is string %}
{{ indent ~ name ~ postfix ~ list }}
{%- else %}{% for item in list %}
{%- if item is not iterable or item is string %}
{{ indent ~ name ~ postfix ~ item }}
{%- else %}{% for key, value in item.items() %}
{{- render_list_of_dictionaries(indent ~ name ~ infix ~ key, value, '', infix, postfix) }}
        {%- endfor %}
      {%- endif %}
    {%- endfor %}
  {%- endif %}
{%- endmacro %}
# HAProxy configuration
#
# **** DO NOT EDIT THIS FILE ****
#
# This file is managed by Salt.
# Any changes will be overwritten.
#------------------
# Global settings
#------------------
global
    log   127.0.0.1:514 len 4096 local0
    log   127.0.0.1:514 len 4096 local1
    stats socket /var/run/haproxy.stat mode 660 level admin
    user haproxy
    group haproxy
    maxconn 200000
    spread-checks 4
    tune.bufsize 32768
    log-send-hostname {{ server_name }}
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets
    ssl-default-bind-ciphers !EDH:!RC4:!ADH:!DSS:HIGH:+AES128:+AES256-SHA256:+AES128-SHA256:+SHA:!3DES:!aNULL:!eNULL
    tune.ssl.default-dh-param 2048
    tune.ssl.cachesize 1000000
    tune.ssl.lifetime 2h
    tune.ssl.maxrecord 1500

defaults
    log global
    mode http
    retries 3
    balance roundrobin
    option	dontlognull
    option	abortonclose
    #option	forwardfor
    option      http-keep-alive
    option      tcpka
    option      redispatch
    option      contstats
{% raw %}
    log-format "[%tr] %ft/%b/%s %TR/%Tw/%Th/%Tc/%Tr/%Ta %ST %B %CC %CS %tsc %ci:%cp/%fi:%fp %sslv/%sslc %ac/%fc/%bc/%sc/%rc %sq/%bq %{+Q}r {%[capture.req.hdr(0)]|%[capture.req.hdr(3)]|%[capture.req.hdr(4)]|%[capture.req.hdr(1)]|%[capture.req.hdr(2)]}"
{% endraw %}
    timeout client          60s
    timeout connect         15s
    timeout server          60s
    timeout check           30s
    timeout tunnel          60s
    timeout http-keep-alive 10s
    timeout http-request    30s
    timeout queue           30s
    timeout tarpit          60s
    default-server inter 3s rise 2 fall 3

backend st_src_global
    stick-table type ip size 1m expire 10s store http_req_rate(10s)

backend st_src_websocket
    stick-table type ip size 1m expire 10m store http_req_rate(10m)

backend st_src_api
    stick-table type ip size 1m expire 10m store http_req_rate(10m)

backend st_ssl_stats
    stick-table type string len 32 size 200 expire 24d store http_req_rate(24d)

backend st_dummy
    stick-table type string len 128 size 2k expire 1d store bytes_out_rate(1d)

