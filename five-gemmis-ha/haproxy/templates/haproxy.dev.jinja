listen admin
    bind *:1936
    acl office_allowed src 125.228.105.246/32
    acl restricted_url path_beg /haproxy
    http-request deny if restricted_url !office_allowed
    option dontlog-normal
    mode http
    stats enable
    stats uri /haproxy?stats
    stats hide-version
    stats refresh 30s
    stats show-node

{%- if salt['pillar.get']('server:haproxy:promexporter', False) %}
frontend prometheus
    bind *:8404
    mode http
    http-request use-service prometheus-exporter if { path /metrics }
    no log
{%- endif %}
