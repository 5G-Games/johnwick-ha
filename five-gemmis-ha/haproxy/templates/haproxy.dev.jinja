    {%- endif %}
    {%- if 'maxconn' in frontend %}
    {{- render_list_of_dictionaries('maxconn      ', frontend.maxconn) }}
    {%- endif %}
    {%- if 'options' in frontend %}
    {{- render_list_of_dictionaries('option', frontend.options) }}
    {%- endif %}
    {%- if 'http_request' in frontend %}
    {{- render_list_of_dictionaries('http-request', frontend.http_request) }}
    {%- endif %}
    {%- if 'captures' in frontend %}
    {{- render_list_of_dictionaries(' ',frontend.captures) }}
    {%- endif %}
    {%- if 'errorfile_503' in frontend %}
